# ─── Hermes connection (SERVER-SIDE ONLY — never prefix with NEXT_PUBLIC_) ───
# The Hermes API server endpoint. Swap this one value when the host is ready.
#   - Same machine as Hermes:  http://127.0.0.1:8642
#   - Remote host:             https://hermes.example.com   (behind TLS)
HERMES_API_URL=http://127.0.0.1:8642
# Bearer token from the Hermes instance's API_SERVER_KEY.
HERMES_API_KEY=

# Model name the API server exposes (OpenAI-compatible "model" field).
HERMES_MODEL=hermes-agent

# Set to 1 to run WITHOUT a real Hermes — streams a canned mock response so the
# whole app works end-to-end before you have the host. Set to 0 (or unset) once
# HERMES_API_URL/KEY point at a live agent.
HERMES_MOCK=1

# ─── Access control (single code box at "/") ───
# A contestant enters a code; the server routes by which set it belongs to.
# Give each contestant a UNIQUE code — the code is their identity, so per-user
# chat tracking is automatic (no database needed).
ACCESS_CODES=demo123,player-one,player-two

# Admin code(s) for the read-only observer. Same box as contestants — the
# server decides the role, so the observer entrance is never advertised. Use a
# LONG, RANDOM value (treat it like a password). Comma-separated for multiple.
ADMIN_CODES=change-me-to-a-long-random-string

# Secret used to sign session/admin cookies. Generate with: openssl rand -hex 32
AUTH_SECRET=dev-only-insecure-secret-change-in-production

# ─── Verdict feed (read-only Chromia, no secret/key needed) ───
# The right-side panel shows on-chain Atbash verdicts. Each contestant follows
# their OWN agent: either bound when the admin mints their code, or set by the
# contestant from the panel itself. These are PUBLIC chain reads — only the
# agent's PUBLIC key is ever needed (never a private key).
CHROMIA_NODE_URL=https://node0.testnet.chromia.com:7740
CHROMIA_BLOCKCHAIN_RID=B91106947F1EAED7B5D789C7D35755330A8A7DD7CB990D59366114EFFB79ED10

# Fallback agent shown when a contestant's code has no bound agent and they
# haven't set one yet (e.g. the static demo codes). Leave blank to require an
# explicit agent for every contestant.
FEED_AGENT_PUBKEY=033d3b7e07267031d5e9658a35c841f4c79eb5ae9d88da4db94c2cd34c280223a1
