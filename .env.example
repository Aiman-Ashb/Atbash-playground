# ─── Hermes connection (SERVER-SIDE ONLY — never prefix with NEXT_PUBLIC_) ───
# The Hermes API server endpoint. Swap this one value when the host is ready.
#   - Same machine as Hermes:  http://127.0.0.1:8642
#   - Remote host:             https://hermes.example.com   (behind TLS)
HERMES_API_URL=http://127.0.0.1:8642

# Bearer token from the Hermes instance's API_SERVER_KEY.
HERMES_API_KEY=

# Model name the API server exposes (OpenAI-compatible "model" field).
HERMES_MODEL=hermes-agent

# Set to 1 to run WITHOUT a real Hermes — streams a canned mock response so the
# whole app works end-to-end before you have the host. Set to 0 (or unset) once
# HERMES_API_URL/KEY point at a live agent.
HERMES_MOCK=1

# ─── Access control ───
# Comma-separated list of valid contestant access codes (each starts a session).
ACCESS_CODES=demo123,player-one,player-two

# Admin password for the read-only observer view (separate from contestant codes).
ADMIN_PASSWORD=change-me

# Secret used to sign session/admin cookies. Generate with: openssl rand -hex 32
AUTH_SECRET=dev-only-insecure-secret-change-in-production
